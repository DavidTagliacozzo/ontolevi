  <rdf:Description rdf:about="http://purl.org/vocab/frbr/core#CorporateBody">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">corporate body</rdfs:label>
    <rdfs:comment xml:lang="en">An organization or group of individuals and/or organizations acting as a unit.

The entity defined as corporate body encompasses organizations and groups of individuals and/or organizations that are identified by a particular name, including occasional groups and groups that are constituted as meetings, conferences, congresses, expeditions, exhibitions, festivals, fairs, etc.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.org/vocab/frbr/core#ResponsibleEntity"/>
  </rdf:Description>
