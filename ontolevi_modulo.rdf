    <rdfs:domain rdf:resource="http://purl.org/vocab/frbr/core#Endeavour"/>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
