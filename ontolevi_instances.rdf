  <rdf:Description rdf:about="#cit_lilit-zingaro-cites-let-amici-cristiani">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.org/spar/cito/Citation"/>
    <cito:hasCitingEntity rdf:resource="#m_1981-ST-LILIT"/>
    <cito:hasCitedEntity rdf:resource="#let_amici-cristiani_s.d."/>
    <cito:hasCitationCharacterization rdf:resource="http://purl.org/spar/cito/citesAsSourceDocument"/>
    <dcterms:description xml:lang="it">Notizia di una lettera, scritta in tedesco dietro autorizzazione della direzione del Lager di Auschwitz, che Levi decide di indirizzare non alla famiglia bensí ad «amici cristiani», probabilmente a Bianca Guidetti Serra. La lettera non giunse a destinazione.</dcterms:description> 
  </rdf:Description>
