  <rdf:Description rdf:about="#journal_sigma">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.org/spar/fabio/Journal"/>
    <rdfs:label>Sigma. Rivista trimestrale di letteratura</rdfs:label>
    <dcterms:title>Sigma. Rivista trimestrale di letteratura</dcterms:title>
    <dcterms:description>«Sigma» avvia le pubblicazioni nella primavera 1964 come continuazione della precedente «Cratilo»; la sede e a Torino benché l’editore Silva operi a Genova. Il gruppo redazionale è formato da Giorgio Barberi-Squarotti [sic], Gian Luigi Beccaria, Giampiero Bona, Eugenio Corsini, Angelo Del Boca, Albino Galvano, Claudio Gorlier, Marziano Guglielminetti, Claudio Magris, Oscar Navarro, Sergio Pautasso (direttore responsabile) e Gian Franco Torcellan: vi figurano dunque alcuni giovani docenti destinati a chiara fama, e ai collaboratori si aggiungerà ben presto Furio Jesi. Fin dal primo fascicolo «Sigma» vanta ospiti stranieri illustri: Viggo Brondal, Gilles Deleuze, William Empson, Hugo Friedrich, Hans Georg Gadamer.</dcterms:description>
    <dcterms:publisher rdf:resource="#publisher_silva"/>
    <schema:location rdf:resource="#place_torino"/>
    <ontolevi:permalinkAcnp rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI"
  >https://acnpsearch.unibo.it/journal/39990</ontolevi:permalinkAcnp>
<ontolevi:codiceAcnp rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
  >39990</ontolevi:codiceAcnp>
   </rdf:Description>
