  <rdf:Description rdf:about="#m_1961-INT-ASSOLTO_1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.org/spar/fabio/Manifestation"/>
    <dcterms:description xml:lang="it">Occhiello: «Ieri sera a tarda ora la sentenza del Tribunale di Genova». Sommario: «Al centro del dibattimento un articolo nel quale si afferma che 'gli ebrei sono deicidi in atto'. Il PM aveva chiesto undici mesi di reclusione».</dcterms:description>
    <rdfs:label xml:lang="it">Assolto dalle accuse… [Il Secolo XIX - 1961-12-10]</rdfs:label>
    <frbr:partOf rdf:resource="#manifestation_newspissue_il-secolo-xix-genova_nodate_nodate_1961-12-10"/>
    <prism:publicationDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1961-12-10</prism:publicationDate>
    <frbr:embodimentOf rdf:resource="#e_1961-INT-ASSOLTO"/>
    <prism:pageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">5</prism:pageRange>
    <dcterms:title xml:lang="it">Assolto dalle accuse di vilipendio e di diffamazione il giudice torinese querelato da un gruppo di ebrei</dcterms:title>
    <dcterms:isPartOf rdf:resource="#col_InterventOrali"/>
    <schema:author rdf:resource="#agent_bruno-faussone"/>
  </rdf:Description>
